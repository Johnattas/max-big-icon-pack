{
  "name": "max-big-icon-pack",
  "version": "1.0.21",
  "private": true,
  "description": "Pipeline reproduzível que gera o Max Big Icon Pack — icon theme do VS Code baseado no Material Icon Theme com 10.000+ ícones.",
  "author": {
    "name": "Johnattas Santana"
  },
  "license": "MIT",
  "homepage": "https://github.com/Johnattas/max-big-icon-pack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Johnattas/max-big-icon-pack.git"
  },
  "bugs": {
    "url": "https://github.com/Johnattas/max-big-icon-pack/issues"
  },
  "dependencies": {
    "cson": "8.4.0",
    "devicon": "2.17.0",
    "less": "4.6.7",
    "material-icon-theme": "5.36.1",
    "simple-icons": "16.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@types/less": "3.0.8",
    "@types/node": "24.0.14",
    "playwright": "1.60.0",
    "tsx": "4.22.3",
    "typescript": "5.8.3",
    "vitest": "4.1.7"
  },
  "scripts": {
    "import-icons": "tsx ./scripts/import-icons/run.ts",
    "preview": "node scripts/preview/gen-preview.mjs && node scripts/preview/gen-gallery.mjs",
    "package": "cd dist-theme && npx @vscode/vsce package",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-type-safety": "tsc -p ./",
    "lint": "biome check .",
    "format": "biome format --write ."
  }
}
